{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
{{ if eq .chezmoi.osRelease.id "manjaro" -}}
pamac install --no-confirm --no-upgrade neovim tmux fish fd sd ripgrep git git-delta docker docker-compose rsync direnv fzf kitty nodejs-lts-gallium npm bat\
        yubikey-manager yubikey-personalization yubico-pam pam-u2f gnome-shell-extension-pop-shell xorg-xprop github-cli glab
pamac build --no-confirm google-chrome nerd-fonts-source-code-pro miniconda3 gnome-shell-extension-unite
{{ end -}}
{{ if eq .chezmoi.osRelease.id "ubuntu" -}}
sudo add-apt-repository ppa:neovim-ppa/stable -y
sudo apt-add-repository ppa:fish-shell/release-3 -y
curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash -
sudo apt-get update
sudo apt-get install build-essential software-properties-common neovim tmux fish fd-find ripgrep git rsync direnv nodejs
pamac build --no-confirm google-chrome nerd-fonts-source-code-pro miniconda3 gnome-shell-extension-unite
ln -s $(which fdfind) ~/.local/bin/fd
curl https://github.com/dandavison/delta/releases/download/0.13.0/git-delta_0.13.0_amd64.deb
sudo dpkg -i git-delta_0.13.0_amd64.deb
rm git-delta_0.13.0_amd64.deb
{{ end -}}
{{ end -}}
