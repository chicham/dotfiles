#!/bin/bash

PREFIX=~/.local/bin
mkdir -p $PREFIX

FD_VERSION=8.7.0
curl -L https://github.com/sharkdp/fd/releases/download/v$FD_VERSION/fd-v$FD_VERSION-x86_64-unknown-linux-musl.tar.gz > /tmp/fd-$FD_VERSION.tar.gz && mkdir -p /tmp/fd-$FD_VERSION && tar -xf /tmp/fd-$FD_VERSION.tar.gz -C /tmp/fd-$FD_VERSION --strip-components=1 && mv /tmp/fd-$FD_VERSION/fd ~/.local/bin && chmod u+x ~/.local/bin/fd && rm -rf /tmp/fd-$FD_VERSION*

RIPGREP_VERSION=13.0.0
curl -L https://github.com/BurntSushi/ripgrep/releases/download/$RIPGREP_VERSION/ripgrep-$RIPGREP_VERSION-x86_64-unknown-linux-musl.tar.gz > /tmp/ripgrep-$RIPGREP_VERSION.tar.gz && mkdir -p /tmp/ripgrep-$RIPGREP_VERSION && tar -xf /tmp/ripgrep-$RIPGREP_VERSION.tar.gz -C /tmp/ripgrep-$RIPGREP_VERSION --strip-components=1 && mv /tmp/ripgrep-$RIPGREP_VERSION/rg ~/.local/bin && chmod u+x ~/.local/bin/rg && rm -rf /tmp/ripgrep-$RIPGREP_VERSION*

DELTA_VERSION=0.16.5
curl -L https://github.com/dandavison/delta/releases/download/$DELTA_VERSION/delta-$DELTA_VERSION-x86_64-unknown-linux-musl.tar.gz  > /tmp/delta-$DELTA_VERSION.tar.gz && mkdir -p /tmp/delta-$DELTA_VERSION && tar -xf /tmp/delta-$DELTA_VERSION.tar.gz -C /tmp/delta-$DELTA_VERSION --strip-components=1 && mv /tmp/delta-$DELTA_VERSION/delta ~/.local/bin && chmod u+x ~/.local/bin/delta && rm -rf /tmp/delta-$DELTA_VERSION*

EXA_VERSION=0.10.1
curl -L https://github.com/ogham/exa/releases/download/v$EXA_VERSION/exa-linux-x86_64-musl-v$EXA_VERSION.zip > /tmp/exa-$EXA_VERSION.zip && mkdir -p /tmp/exa-$EXA_VERSION && unzip /tmp/exa-$EXA_VERSION.zip -d /tmp/exa-$EXA_VERSION && mv /tmp/exa-$EXA_VERSION/bin/exa ~/.local/bin && chmod u+x ~/.local/bin/exa && rm -rf /tmp/exa-$EXA_VERSION*

BAT_VERSION=0.23.0
curl -L https://github.com/sharkdp/bat/releases/download/v$BAT_VERSION/bat-v$BAT_VERSION-i686-unknown-linux-musl.tar.gz > /tmp/bat-$BAT_VERSION.tar.gz && mkdir -p /tmp/bat-$BAT_VERSION && tar -xf /tmp/bat-$BAT_VERSION.tar.gz -C /tmp/bat-$BAT_VERSION --strip-components=1 && mv /tmp/bat-$BAT_VERSION/bat ~/.local/bin && chmod u+x ~/.local/bin/bat && rm -rf /tmp/bat-$BAT_VERSION*


OP_VERSION=2.18.0
curl -l https://cache.agilebits.com/dist/1P/op2/pkg/v$OP_VERSION/op_linux_amd64_v$OP_VERSION.zip  > /tmp/op-$OP_VERSION.zip && unzip /tmp/op-$OP_VERSION.zip -d /tmp/op-$OP_VERSION && mv /tmp/op-$OP_VERSION/op ~/.local/bin && chmod u+x ~/.local/bin/op && rm -rf /tmp/op-$OP_VERSION*

GIT_BUG=0.8.0
curl -l https://github.com/MichaelMure/git-bug/releases/download/v0.8.0/git-bug_linux_amd64 > ~/.local/bin/git-bug && chmod u+x ~/.local/bin/git-bug

bin_path=$PREFIX
curl -sfL https://direnv.net/install.sh | bash
curl -sS https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | bash
curl -sS https://starship.rs/install.sh | sh -s -- --bin-dir $PREFIX --yes
curl micro.mamba.pm/install.sh | bash
