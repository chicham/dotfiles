{
  "coc.source.vimtex.enable": true,
  "coc.preferences.formatOnType": true,
  "coc.preferences.formatOnSaveFiletypes": [],
  "diagnostic.errorSign": "",
  "diagnostic.warningSign": "",
  "diagnostic.infoSign": "",
  "diagnostic.hintSign": "",
  "diagnostic.virtualText": true,
  "diagnostic.messageTarget": "echo",
  "json.format.enable": true,
  "python.linting.enabled": true,
  "python.linting.lintOnSave": true,
  "python.linting.pylintEnabled": false,
  "python.linting.pytypeEnabled": true,
  "python.formatting.provider": "black",
  "python.analysis.diagnosticSeverityOverrides": {
    "reportGeneralTypeIssues": "none",
    "reportOptionalMemberAccess": "none"
  },
  "python.analysis.autoImportCompletions": true,
  "python.analysis.useLibraryCodeForTypes": true,
  "pyright.organizeimports.provider": "isort",
  "sh.highlightParsingErrors": true,
  "suggest.enablePreview": true,
  "suggest.minTriggerInputLength": 1,
  "suggest.snippetIndicator": "[S] ",
  "suggest.maxCompleteItemCount": 10,
  "suggest.noselect": false,
  "snippets.ultisnips.directories": ["UltiSnips", "$HOME/.snippets"],
  "yaml.validate": true,
  "yaml.hover": true,
  "yaml.completion": true,
  "yaml.format.enable": true,
  "yaml.format.singleQuote": true
}
